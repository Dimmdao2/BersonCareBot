[
	{
		"id": "telegram.admin.start",
		"source": "telegram",
		"event": "message.received",
		"priority": 10,
		"match": {
			"input": { "text": "/start" },
			"actor": { "isAdmin": true }
		},
		"steps": [
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"templateKey": "telegram:admin.menu.hint",
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 }
				}
			}
		]
	},
	{
		"id": "telegram.admin.stats.bookings",
		"source": "telegram",
		"event": "message.received",
		"priority": 10,
		"match": {
			"input": { "action": "admin.stats.bookings" },
			"actor": { "isAdmin": true }
		},
		"conditions": [
			{
				"kind": "context.query",
				"name": "adminStats",
				"query": { "type": "admin.stats" }
			}
		],
		"steps": [
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"templateKey": "telegram:admin.stats.bookings",
					"vars": {
						"activeBookings": "{{queries.adminStats.activeBookings}}"
					},
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 }
				}
			}
		]
	},
	{
		"id": "telegram.admin.stats.users",
		"source": "telegram",
		"event": "message.received",
		"priority": 10,
		"match": {
			"input": { "action": "admin.stats.users" },
			"actor": { "isAdmin": true }
		},
		"conditions": [
			{
				"kind": "context.query",
				"name": "adminStats",
				"query": { "type": "admin.stats" }
			}
		],
		"steps": [
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"templateKey": "telegram:admin.stats.users",
					"vars": {
						"telegramTotal": "{{queries.adminStats.userCountsByIntegration.telegram.total}}",
						"telegramWithPhone": "{{queries.adminStats.userCountsByIntegration.telegram.withPhone}}",
						"rubitimeTotal": "{{queries.adminStats.userCountsByIntegration.rubitime.total}}"
					},
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 }
				}
			}
		]
	},
	{
		"id": "telegram.admin.questions.unanswered",
		"source": "telegram",
		"event": "message.received",
		"priority": 10,
		"match": {
			"input": { "action": "admin.questions.unanswered" },
			"actor": { "isAdmin": true }
		},
		"steps": [
			{
				"action": "question.listUnanswered",
				"mode": "sync",
				"params": {
					"limit": 20
				}
			}
		]
	},
	{
		"id": "telegram.admin.dialogs.open",
		"source": "telegram",
		"event": "message.received",
		"priority": 10,
		"match": {
			"input": { "action": "admin.dialogs.open" },
			"actor": { "isAdmin": true }
		},
		"steps": [
			{
				"action": "conversation.listOpen",
				"mode": "sync",
				"params": {
					"source": "telegram",
					"limit": 10
				}
			}
		]
	},
	{
		"id": "telegram.admin.dialogs.view",
		"source": "telegram",
		"event": "callback.received",
		"priority": 10,
		"match": {
			"input": { "action": "dialogs.view" },
			"actor": { "isAdmin": true }
		},
		"steps": [
			{
				"action": "conversation.show",
				"mode": "sync",
				"params": {
					"conversationId": "{{input.conversationId}}"
				}
			},
			{
				"action": "callback.answer",
				"mode": "async",
				"params": {
					"callbackQueryId": "{{input.callbackQueryId}}"
				}
			}
		]
	},
	{
		"id": "telegram.admin.reply.start",
		"source": "telegram",
		"event": "callback.received",
		"priority": 10,
		"match": {
			"input": { "action": "admin_reply" },
			"actor": { "isAdmin": true }
		},
		"steps": [
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "admin_reply:{{input.conversationId}}"
				}
			},
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"templateKey": "telegram:admin.reply.prompt",
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 }
				}
			},
			{
				"action": "callback.answer",
				"mode": "async",
				"params": {
					"callbackQueryId": "{{input.callbackQueryId}}"
				}
			}
		]
	},
	{
		"id": "telegram.admin.reply.continue",
		"source": "telegram",
		"event": "callback.received",
		"priority": 10,
		"match": {
			"input": { "action": "admin_reply_continue" },
			"actor": { "isAdmin": true }
		},
		"steps": [
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "admin_reply:{{input.conversationId}}"
				}
			},
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"templateKey": "telegram:admin.reply.prompt",
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 }
				}
			},
			{
				"action": "callback.answer",
				"mode": "async",
				"params": {
					"callbackQueryId": "{{input.callbackQueryId}}"
				}
			}
		]
	},
	{
		"id": "telegram.admin.reply.message",
		"source": "telegram",
		"event": "message.received",
		"priority": 10,
		"match": {
			"context": { "replyMode": true },
			"input": {
				"textPresent": true,
				"excludeActions": ["admin.dialogs.open", "admin.stats.bookings", "admin.stats.users", "admin.questions.unanswered"],
				"excludeTexts": ["/start"]
			},
			"actor": { "isAdmin": true }
		},
		"steps": [
			{
				"action": "conversation.admin.reply",
				"mode": "sync",
				"params": {
					"conversationId": "{{context.replyConversationId}}"
				}
			},
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "idle"
				}
			}
		]
	},
	{
		"id": "telegram.admin.dialog.close",
		"source": "telegram",
		"event": "callback.received",
		"priority": 10,
		"match": {
			"input": { "action": "admin_close_dialog" },
			"actor": { "isAdmin": true }
		},
		"steps": [
			{
				"action": "conversation.close",
				"mode": "sync",
				"params": {
					"conversationId": "{{input.conversationId}}"
				}
			},
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "idle"
				}
			},
			{
				"action": "callback.answer",
				"mode": "async",
				"params": {
					"callbackQueryId": "{{input.callbackQueryId}}"
				}
			}
		]
	}
]
