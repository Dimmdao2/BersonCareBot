[
	{
		"id": "telegram.start",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"input": { "text": "/start" }
		},
		"steps": [
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "idle"
				}
			},
			{
				"action": "message.replyKeyboard.show",
				"mode": "async",
				"params": {
					"chatId": "{{actor.chatId}}",
					"templateKey": "telegram:welcome",
					"keyboard": [
						[
							{ "textTemplateKey": "telegram:menu.book" },
							{ "textTemplateKey": "telegram:menu.ask" },
							{ "textTemplateKey": "telegram:menu.more" }
						]
					],
					"resizeKeyboard": true
				}
			}
		]
	},
	{
		"id": "telegram.ask",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"input": { "action": "question.ask" }
		},
		"steps": [
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "waiting_for_question"
				}
			},
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"message": {},
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 },
					"templateKey": "telegram:describeQuestion"
				}
			}
		]
	},
	{
		"id": "telegram.ask.question",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"context": { "conversationState": "waiting_for_question" },
			"input": {
				"textPresent": true,
				"excludeActions": ["booking.open", "question.ask", "menu.more"],
				"excludeTexts": ["/start"]
			}
		},
		"steps": [
			{
				"action": "draft.upsertFromMessage",
				"mode": "sync",
				"params": {
					"source": "telegram"
				}
			},
			{
				"action": "draft.send",
				"mode": "sync",
				"params": {
					"source": "telegram",
					"adminTemplateKey": "telegram:adminForward"
				}
			},
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "idle"
				}
			},
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"message": {},
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 },
					"templateKey": "telegram:questionAccepted"
				}
			}
		]
	},
	{
		"id": "telegram.draft.replace",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"context": { "hasActiveDraft": true, "hasOpenConversation": false },
			"input": {
				"textPresent": true,
				"excludeActions": ["booking.open", "question.ask", "menu.more"],
				"excludeTexts": ["/start"]
			}
		},
		"steps": [
			{
				"action": "draft.replaceFromMessage",
				"mode": "sync",
				"params": {
					"source": "telegram"
				}
			},
			{
				"action": "message.inlineKeyboard.show",
				"mode": "async",
				"params": {
					"chatId": "{{actor.chatId}}",
					"templateKey": "telegram:confirmQuestion",
					"inlineKeyboard": [
						[
							{ "text": "Отправить вопрос", "callbackData": "send_question" }
						]
					]
				}
			}
		]
	},
	{
		"id": "telegram.draft.send",
		"source": "telegram",
		"event": "callback.received",
		"match": {
			"context": { "hasActiveDraft": true },
			"input": { "action": "send_question" }
		},
		"steps": [
			{
				"action": "draft.send",
				"mode": "sync",
				"params": {
					"source": "telegram",
					"adminTemplateKey": "telegram:adminForward"
				}
			},
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "idle"
				}
			},
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"message": {},
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 },
					"templateKey": "telegram:questionAccepted"
				}
			},
			{
				"action": "callback.answer",
				"mode": "async",
				"params": {
					"callbackQueryId": "{{input.callbackQueryId}}"
				}
			}
		]
	},
	{
		"id": "telegram.conversation.user.message",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"actor": { "isAdmin": false },
			"context": { "hasOpenConversation": true },
			"input": { "textPresent": true, "excludeTexts": ["/start"] }
		},
		"steps": [
			{
				"action": "conversation.user.message",
				"mode": "sync",
				"params": {
					"source": "telegram"
				}
			},
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"message": {},
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 },
					"templateKey": "telegram:dialogMessageAccepted"
				}
			}
		]
	},
	{
		"id": "telegram.booking.open",
		"source": "telegram",
		"event": "message.received",
