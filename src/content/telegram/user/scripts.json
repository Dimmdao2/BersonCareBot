	{
		"id": "telegram.debug.show_my_id",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"input": { "action": "debug.show_my_id" }
		},
		"steps": [
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"templateKey": "telegram:showMyId",
					"vars": {
						"channelId": "{{actor.channelUserId}}"
					},
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 }
				}
			}
		]
	},
	{
		"id": "telegram.ask",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"actor": { "isAdmin": false },
			"input": { "action": "question.ask" }
		},
		"steps": [
			{
				"action": "admin.forward",
				"mode": "async",
				"params": {
					"chatId": "{{facts.adminChatId}}",
					"templateKey": "telegram:adminForward",
					"vars": {
						"name": "{{facts.actor.displayName}}",
						"username": "{{actor.username}}",
						"channelId": "{{actor.channelUserId}}",
						"messageText": "{{input.text}}"
					}
				}
			},
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"message": {},
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 },
					"templateKey": "telegram:questionAccepted"
				}
			}
		]
	},
	{
		"id": "telegram.ask.question",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"context": { "conversationState": "waiting_for_question" },
			"input": {
				"textPresent": true,
				"excludeActions": ["booking.open", "question.ask", "menu.more", "cabinet.open"],
				"excludeTexts": ["/start", "⚙️ Меню", "Меню", "❓ Задать вопрос", "Задать вопрос", "📅 Запись на приём", "Запись на приём", "👤 Кабинет", "Кабинет"]
			}
		},
		"steps": [
			{
				"action": "draft.upsertFromMessage",
				"mode": "sync",
				"params": {
					"source": "telegram"
				}
			},
			{
				"action": "draft.send",
				"mode": "sync",
				"params": {
					"source": "telegram",
					"adminTemplateKey": "telegram:adminForward"
				}
			},
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "idle"
				}
			},
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"message": {},
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 },
					"templateKey": "telegram:questionAccepted"
				}
			}
		]
	},
	{
		"id": "telegram.draft.replace",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"context": { "hasActiveDraft": true, "hasOpenConversation": false },
			"input": {
				"textPresent": true,
				"excludeActions": ["booking.open", "question.ask", "menu.more", "cabinet.open"],
				"excludeTexts": ["/start", "⚙️ Меню", "Меню", "❓ Задать вопрос", "Задать вопрос", "📅 Запись на приём", "Запись на приём", "👤 Кабинет", "Кабинет"]
			}
		},
		"steps": [
			{
				"action": "draft.replaceFromMessage",
				"mode": "sync",
				"params": {
					"source": "telegram"
				}
			},
			{
				"action": "message.inlineKeyboard.show",
				"mode": "async",
				"params": {
					"chatId": "{{actor.chatId}}",
					"templateKey": "telegram:confirmQuestion",
					"inlineKeyboard": [
						[
							{ "text": "Отправить вопрос", "callbackData": "send_question" }
						]
					]
				}
			}
		]
	},
	{
		"id": "telegram.draft.send",
		"source": "telegram",
