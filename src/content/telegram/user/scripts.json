					"text": "🔔 Настройки уведомлений\n\nВыберите интересующие вас категории:",
					"inlineKeyboard": [
						[
							{
								"textTemplateKey": "telegram:notifications.label.spb",
								"prefixTemplateKey": "telegram:notifications.togglePrefix",
								"callbackData": "notifications.toggle.spb"
							}
						],
						[
							{
								"textTemplateKey": "telegram:notifications.label.msk",
								"prefixTemplateKey": "telegram:notifications.togglePrefix",
								"callbackData": "notifications.toggle.msk"
							}
						],
						[
							{
								"textTemplateKey": "telegram:notifications.label.online",
								"prefixTemplateKey": "telegram:notifications.togglePrefix",
								"callbackData": "notifications.toggle.online"
							}
						],
						[
							{
								"textTemplateKey": "telegram:notifications.label.bookings",
								"prefixTemplateKey": "telegram:notifications.togglePrefix",
								"callbackData": "notifications.toggle.bookings"
							}
						],
						[{ "text": "⬅️ Назад", "callbackData": "menu.back" }]
					]
				}
			},
			{
				"action": "callback.answer",
				"mode": "async",
				"params": { "callbackQueryId": "{{input.callbackQueryId}}" }
			}
		]
	},
	{
		"id": "telegram.bookings.show",
		"source": "telegram",
		"event": "callback.received",
		"match": {
			"input": { "action": "bookings.show" },
			"context": { "linkedPhone": true }
		},
		"conditions": [
			{
				"kind": "context.query",
				"name": "bookings",
				"query": { "type": "bookings.forUser", "userId": "{{context.phoneNormalized}}" }
			}
		],
		"steps": [
			{
				"action": "message.edit",
				"mode": "async",
				"params": {
					"_when": { "path": "queries.bookings.items.length", "equals": 0 },
					"chatId": "{{actor.chatId}}",
					"messageId": "{{input.messageId}}",
					"templateKey": "telegram:noBookings",
					"vars": { "queries": "{{queries}}" },
					"inlineKeyboard": [
						[{ "textTemplateKey": "telegram:bookingsScreen.prepare", "callbackData": "info.prepare" }],
						[{ "textTemplateKey": "telegram:bookingsScreen.address", "callbackData": "info.address" }],
						[{ "text": "⬅️ Назад", "callbackData": "menu.back" }]
					]
				}
			},
			{
				"action": "message.edit",
				"mode": "async",
				"params": {
					"_when": { "path": "queries.bookings.items.length", "truthy": true },
					"chatId": "{{actor.chatId}}",
					"messageId": "{{input.messageId}}",
					"templateKey": "telegram:bookingsList",
					"vars": { "queries": "{{queries}}" },
					"inlineKeyboard": [
						[{ "textTemplateKey": "telegram:bookingsScreen.prepare", "callbackData": "info.prepare" }],
						[{ "textTemplateKey": "telegram:bookingsScreen.address", "callbackData": "info.address" }],
						[{ "text": "⬅️ Назад", "callbackData": "menu.back" }]
					]
				}
			},
			{
				"action": "callback.answer",
				"mode": "async",
				"params": { "callbackQueryId": "{{input.callbackQueryId}}" }
			}
		]
	},
	{
		"id": "telegram.info.prepare",
		"source": "telegram",
		"event": "callback.received",
		"match": {
			"input": { "action": "info.prepare" }
		},
		"steps": [
			{
				"action": "message.edit",
				"mode": "async",
				"params": {
					"chatId": "{{actor.chatId}}",
					"messageId": "{{input.messageId}}",
					"templateKey": "telegram:info.prepare.body",
					"inlineKeyboard": [
						[{ "text": "⬅️ Назад", "callbackData": "bookings.show" }]
					]
				}
			},
			{
				"action": "callback.answer",
				"mode": "async",
				"params": { "callbackQueryId": "{{input.callbackQueryId}}" }
			}
		]
	},
	{
		"id": "telegram.info.address",
		"source": "telegram",
		"event": "callback.received",
		"match": {
			"input": { "action": "info.address" }
		},
		"steps": [
			{
				"action": "message.edit",
				"mode": "async",
				"params": {
					"chatId": "{{actor.chatId}}",
					"messageId": "{{input.messageId}}",
					"templateKey": "telegram:info.address.body",
					"inlineKeyboard": [
						[{ "text": "⬅️ Назад", "callbackData": "bookings.show" }]
					]
				}
			},
			{
				"action": "callback.answer",
				"mode": "async",
				"params": { "callbackQueryId": "{{input.callbackQueryId}}" }
			}
		]
	},
	{
		"id": "telegram.menu.back",
		"source": "telegram",
		"event": "callback.received",
		"match": {
			"input": { "action": "menu.back" }
		},
		"steps": [
			{
				"action": "message.edit",
				"mode": "async",
				"params": {
					"chatId": "{{actor.chatId}}",
					"messageId": "{{input.messageId}}",
					"templateKey": "telegram:chooseMenu",
					"menu": "main"
				}
			},
			{
				"action": "callback.answer",
				"mode": "async",
				"params": { "callbackQueryId": "{{input.callbackQueryId}}" }
			}
		]
	},
	{
		"id": "telegram.menu.default",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"actor": { "isAdmin": false },
			"input": {
				"textPresent": true,
				"excludeActions": ["booking.open", "menu.more", "cabinet.open"],
				"excludeTexts": ["/start", "⚙️ Меню", "Меню", "📅 Запись на приём", "Запись на приём", "👤 Кабинет", "Кабинет"]
			}
		},
		"steps": [
			{
				"action": "admin.forward",
				"mode": "async",
				"params": {
					"chatId": "{{facts.adminChatId}}",
					"templateKey": "telegram:adminForward",
					"vars": {
						"name": "{{facts.actor.displayName}}",
						"username": "{{actor.username}}",
						"channelId": "{{actor.channelUserId}}",
						"messageText": "{{input.text}}"
					}
				}
			},
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"message": {},
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 },
					"templateKey": "telegram:questionAccepted"
				}
			}
		]
	}
]
