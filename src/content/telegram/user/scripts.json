	{
		"id": "telegram.bookings.show",
		"source": "telegram",
		"event": "callback.received",
		"match": {
			"input": { "action": "bookings.show" },
			"context": { "linkedPhone": true }
		},
		"conditions": [
			{
				"kind": "context.query",
				"name": "bookings",
				"query": { "type": "bookings.forUser", "userId": "{{context.phoneNormalized}}" }
			}
		],
		"steps": [
			{
				"action": "message.edit",
				"mode": "async",
				"params": {
					"_when": { "path": "queries.bookings.items.length", "equals": 0 },
					"chatId": "{{actor.chatId}}",
					"messageId": "{{input.messageId}}",
					"templateKey": "telegram:noBookings",
					"vars": { "queries": "{{queries}}" },
					"inlineKeyboard": [
						[{ "text": "⬅️ Назад", "callbackData": "menu.back" }]
					]
				}
			},
			{
				"action": "message.edit",
				"mode": "async",
				"params": {
					"_when": { "path": "queries.bookings.items.length", "truthy": true },
					"chatId": "{{actor.chatId}}",
					"messageId": "{{input.messageId}}",
					"templateKey": "telegram:bookingsList",
					"vars": { "queries": "{{queries}}" },
					"inlineKeyboard": [
						[{ "text": "⬅️ Назад", "callbackData": "menu.back" }]
					]
				}
			},
			{
				"action": "callback.answer",
				"mode": "async",
				"params": { "callbackQueryId": "{{input.callbackQueryId}}" }
			}
		]
	},
	{
		"id": "telegram.menu.back",
		"source": "telegram",
		"event": "callback.received",
		"match": {
			"input": { "action": "menu.back" }
		},
		"steps": [
			{
				"action": "message.edit",
				"mode": "async",
				"params": {
					"chatId": "{{actor.chatId}}",
					"messageId": "{{input.messageId}}",
					"templateKey": "telegram:chooseMenu",
					"inlineKeyboard": [
						[{ "textTemplateKey": "telegram:moreMenu.notifications", "callbackData": "notifications.show" }],
						[{ "textTemplateKey": "telegram:moreMenu.myBookings", "callbackData": "bookings.show" }]
					]
				}
			},
			{
				"action": "callback.answer",
				"mode": "async",
				"params": { "callbackQueryId": "{{input.callbackQueryId}}" }
			}
		]
	},
	{
		"id": "telegram.menu.default",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"context": { "conversationState": "idle", "hasOpenConversation": false },
			"input": {
				"textPresent": true,
				"excludeActions": ["booking.open", "question.ask", "menu.more"],
				"excludeTexts": ["/start"]
			}
		},
		"steps": [
			{
				"action": "draft.upsertFromMessage",
				"mode": "sync",
				"params": {
					"source": "telegram"
				}
			},
			{
				"action": "message.inlineKeyboard.show",
				"mode": "async",
				"params": {
					"chatId": "{{actor.chatId}}",
					"templateKey": "telegram:confirmQuestion",
					"inlineKeyboard": [
						[
							{ "text": "Отправить вопрос", "callbackData": "send_question" }
						]
					]
				}
			}
		]
	}
]
