					"templateKey": "telegram:bookingOpenPrompt",
					"inlineKeyboard": [
						[
							{
								"textTemplateKey": "telegram:bookingOpenButton",
								"url": "{{facts.links.bookingUrl}}"
							}
						]
					]
				}
			}
		]
	},
	{
		"id": "telegram.booking.open.fallback",
