[
	{
		"id": "telegram.admin.start",
		"source": "telegram",
		"event": "message.received",
		"priority": 10,
		"match": {
			"input": { "text": "/start" },
			"actor": { "isAdmin": true }
		},
		"steps": [
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"templateKey": "telegram:admin.menu.hint",
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 }
				}
			}
		]
	},
	{
		"id": "telegram.admin.stats.bookings",
		"source": "telegram",
		"event": "message.received",
		"priority": 10,
		"match": {
			"input": { "action": "admin.stats.bookings" },
			"actor": { "isAdmin": true }
		},
		"conditions": [
			{
				"kind": "context.query",
				"name": "adminStats",
				"query": { "type": "admin.stats" }
			}
		],
		"steps": [
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"templateKey": "telegram:admin.stats.bookings",
					"vars": {
						"activeBookings": "{{queries.adminStats.activeBookings}}"
					},
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 }
				}
			}
		]
	},
	{
		"id": "telegram.admin.stats.users",
		"source": "telegram",
		"event": "message.received",
		"priority": 10,
		"match": {
			"input": { "action": "admin.stats.users" },
			"actor": { "isAdmin": true }
		},
		"conditions": [
			{
				"kind": "context.query",
				"name": "adminStats",
				"query": { "type": "admin.stats" }
			}
		],
		"steps": [
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"templateKey": "telegram:admin.stats.users",
					"vars": {
						"telegramTotal": "{{queries.adminStats.userCountsByIntegration.telegram.total}}",
						"telegramWithPhone": "{{queries.adminStats.userCountsByIntegration.telegram.withPhone}}",
						"rubitimeTotal": "{{queries.adminStats.userCountsByIntegration.rubitime.total}}"
					},
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 }
				}
			}
		]
	},
	{
		"id": "telegram.start",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"input": { "text": "/start" }
		},
		"steps": [
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "idle"
				}
			},
			{
				"action": "message.replyKeyboard.show",
				"mode": "async",
				"params": {
					"chatId": "{{actor.chatId}}",
					"templateKey": "telegram:welcome",
					"keyboard": [
						[
							{ "textTemplateKey": "telegram:menu.book" },
							{ "textTemplateKey": "telegram:menu.ask" },
							{ "textTemplateKey": "telegram:menu.more" }
						]
					],
					"resizeKeyboard": true
				}
			}
		]
	},
	{
		"id": "telegram.ask",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"input": { "action": "question.ask" }
		},
		"steps": [
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "waiting_for_question"
				}
			},
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"message": {},
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 },
					"templateKey": "telegram:describeQuestion"
				}
			}
		]
	},
	{
		"id": "telegram.ask.question",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"context": { "conversationState": "waiting_for_question" },
			"input": {
				"textPresent": true,
				"excludeActions": ["booking.open", "question.ask", "menu.more"],
				"excludeTexts": ["/start"]
			}
		},
		"steps": [
			{
				"action": "admin.forward",
				"mode": "async",
				"params": {
					"chatId": "{{facts.adminChatId}}",
					"templateKey": "telegram:adminForward",
					"vars": {
						"name": "{{facts.actor.displayName}}",
						"username": "{{actor.username}}",
						"channelId": "{{actor.channelUserId}}",
						"messageText": "{{input.text}}"
					}
				}
			},
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "idle"
				}
			},
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"message": {},
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 },
					"templateKey": "telegram:questionAccepted"
				}
			}
		]
	},
	{
		"id": "telegram.booking.open",
		"source": "telegram",
		"event": "message.received",
