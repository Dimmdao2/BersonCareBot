[
	{
		"id": "telegram.start",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"input": { "text": "/start" }
		},
		"steps": [
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "idle"
				}
			},
			{
				"action": "message.replyKeyboard.show",
				"mode": "async",
				"params": {
					"chatId": "{{actor.chatId}}",
					"templateKey": "telegram:chooseMenu",
					"keyboard": [
						[{ "textTemplateKey": "telegram:menu.book" }],
						[{ "textTemplateKey": "telegram:menu.ask" }],
						[{ "textTemplateKey": "telegram:menu.more" }]
					],
					"resizeKeyboard": true
				}
			}
		]
	},
	{
		"id": "telegram.ask",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"input": { "action": "question.ask" }
		},
		"steps": [
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "waiting_for_question"
				}
			},
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"message": {},
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 },
					"templateKey": "telegram:describeQuestion"
				}
			}
		]
	},
	{
		"id": "telegram.ask.question",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"context": { "conversationState": "waiting_for_question" },
			"input": {
				"textPresent": true,
				"excludeActions": ["booking.open", "question.ask", "menu.more"],
				"excludeTexts": ["/start"]
			}
		},
		"steps": [
			{
				"action": "admin.forward",
				"mode": "async",
				"params": {
					"chatId": "{{context.adminChatId}}",
					"templateKey": "telegram:adminForward",
					"vars": {
						"name": "{{actor.displayName}}",
						"username": "{{actor.username}}",
						"channelId": "{{actor.channelUserId}}",
						"messageText": "{{input.text}}"
					}
				}
			},
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "idle"
				}
			},
			{
				"action": "message.send",
				"mode": "async",
				"params": {
					"recipient": { "chatId": "{{actor.chatId}}" },
					"message": {},
					"delivery": { "channels": ["telegram"], "maxAttempts": 1 },
					"templateKey": "telegram:questionAccepted"
				}
			}
		]
	},
	{
		"id": "telegram.booking.open",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"input": { "action": "booking.open" },
			"context": { "linkedPhone": true }
		},
		"steps": [
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "idle"
				}
			},
			{
				"action": "message.inlineKeyboard.show",
				"mode": "async",
				"params": {
					"chatId": "{{actor.chatId}}",
					"templateKey": "telegram:bookingOpenPrompt",
					"inlineKeyboard": [
						[
							{
								"textTemplateKey": "telegram:bookingOpenButton",
								"url": "{{context.bookingWidgetUrl}}"
							}
						]
					]
				}
			}
		]
	},
	{
		"id": "telegram.contact.link.request.booking",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"input": { "action": "booking.open" },
			"context": { "linkedPhone": false }
		},
		"steps": [
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "await_contact:subscription"
				}
			},
			{
				"action": "message.replyKeyboard.show",
				"mode": "async",
				"params": {
					"chatId": "{{actor.chatId}}",
					"templateKey": "telegram:confirmPhoneForBooking",
					"keyboard": [
						[
							{
								"textTemplateKey": "telegram:requestContact.button",
								"requestContact": true
							}
						]
					],
					"resizeKeyboard": true,
					"oneTimeKeyboard": true
				}
			}
		]
	},
	{
		"id": "telegram.contact.link.request.bookings",
		"source": "telegram",
		"event": "callback.received",
		"match": {
			"input": { "action": "bookings.show" },
			"context": { "linkedPhone": false }
		},
		"steps": [
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "await_contact:subscription"
				}
			},
			{
				"action": "message.replyKeyboard.show",
				"mode": "async",
				"params": {
					"chatId": "{{actor.chatId}}",
					"templateKey": "telegram:confirmPhoneForBooking",
					"keyboard": [
						[
							{
								"textTemplateKey": "telegram:requestContact.button",
								"requestContact": true
							}
						]
					],
					"resizeKeyboard": true,
					"oneTimeKeyboard": true
				}
			},
			{
				"action": "callback.answer",
				"mode": "async",
				"params": {
					"callbackQueryId": "{{input.callbackQueryId}}"
				}
			}
		]
	},
	{
		"id": "telegram.contact.link.confirm",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"context": { "conversationState": "await_contact:subscription" },
			"input": { "phonePresent": true }
		},
		"steps": [
			{
				"action": "user.phone.link",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"phoneNormalized": "{{input.phone}}"
				}
			},
			{
				"action": "user.state.set",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}",
					"state": "idle"
				}
			},
			{
				"action": "message.replyKeyboard.show",
				"mode": "async",
				"params": {
					"chatId": "{{actor.chatId}}",
					"templateKey": "telegram:chooseMenu",
					"keyboard": [
						[{ "textTemplateKey": "telegram:menu.book" }],
						[{ "textTemplateKey": "telegram:menu.ask" }],
						[{ "textTemplateKey": "telegram:menu.more" }]
					],
					"resizeKeyboard": true
				}
			}
		]
	},
	{
		"id": "telegram.contact.link.remind",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"context": { "conversationState": "await_contact:subscription" },
			"input": { "phonePresent": false }
		},
		"steps": [
			{
				"action": "message.replyKeyboard.show",
				"mode": "async",
				"params": {
					"chatId": "{{actor.chatId}}",
					"templateKey": "telegram:confirmPhoneForBooking",
					"keyboard": [
						[
							{
								"textTemplateKey": "telegram:requestContact.button",
								"requestContact": true
							}
						]
					],
					"resizeKeyboard": true,
					"oneTimeKeyboard": true
				}
			}
		]
	},
	{
		"id": "telegram.more.menu",
		"source": "telegram",
		"event": "message.received",
		"match": {
			"input": { "action": "menu.more" }
		},
		"steps": [
			{
				"action": "message.inlineKeyboard.show",
				"mode": "async",
				"params": {
					"chatId": "{{actor.chatId}}",
					"templateKey": "telegram:chooseMenu",
					"inlineKeyboard": [
						[{ "textTemplateKey": "telegram:moreMenu.notifications", "callbackData": "notifications.show" }],
						[{ "textTemplateKey": "telegram:moreMenu.myBookings", "callbackData": "bookings.show" }]
					]
				}
			}
		]
	},
	{
		"id": "telegram.notifications.show",
		"source": "telegram",
		"event": "callback.received",
		"match": {
			"input": { "action": "notifications.show" }
		},
		"steps": [
			{
				"action": "notifications.get",
				"mode": "sync",
				"params": {
					"channelUserId": "{{actor.channelUserId}}"
				}
			},
			{
				"action": "message.edit",
				"mode": "async",
				"params": {
					"chatId": "{{actor.chatId}}",
					"messageId": "{{input.messageId}}",
					"text": "🔔 Настройки уведомлений\n\nВыберите интересующие вас категории:",
					"inlineKeyboard": [
						[
							{
								"textTemplateKey": "telegram:notifications.label.spb",
								"prefixTemplateKey": "telegram:notifications.togglePrefix",
								"callbackData": "notifications.toggle.spb"
							}
						],
						[
							{
								"textTemplateKey": "telegram:notifications.label.msk",
								"prefixTemplateKey": "telegram:notifications.togglePrefix",
								"callbackData": "notifications.toggle.msk"
							}
						],
						[
							{
								"textTemplateKey": "telegram:notifications.label.online",
								"prefixTemplateKey": "telegram:notifications.togglePrefix",
								"callbackData": "notifications.toggle.online"
							}
						],
						[{ "text": "✅ Все категории", "callbackData": "notifications.toggle.all" }],
						[{ "text": "⬅️ Назад", "callbackData": "menu.back" }]
					]
				}
			},
			{
				"action": "callback.answer",
				"mode": "async",
				"params": {
					"callbackQueryId": "{{input.callbackQueryId}}"
				}
			}
		]
	},
