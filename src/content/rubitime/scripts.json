[
  {
    "id": "rubitime.record.created",
    "source": "rubitime",
    "event": "webhook.received",
    "match": {
      "input": {
        "entity": "record",
        "action": "created"
      }
    },
    "steps": [
      {
        "action": "event.log",
        "mode": "sync",
        "params": {
          "eventStore": "booking",
          "source": "{{source}}",
          "eventType": "{{event}}",
          "eventId": "{{meta.eventId}}",
          "occurredAt": "{{meta.occurredAt}}",
          "correlationId": "{{meta.correlationId}}",
          "body": "{{input}}"
        }
      },
      {
        "action": "booking.upsert",
        "mode": "sync",
        "params": {
          "externalRecordId": "{{input.recordId}}",
          "phoneNormalized": "{{input.phone}}",
          "recordAt": "{{input.recordAt}}",
          "status": "created",
          "rubitimeStatusCode": "{{input.statusCode}}",
          "payloadJson": "{{input.record}}",
          "lastEvent": "{{input.action}}"
        }
      },
      {
        "action": "message.send",
        "mode": "async",
        "params": {
          "recipient": {
            "phoneNormalized": "{{input.phone}}"
          },
          "recipientPolicy": {
            "lookupByPhone": true,
            "preferredLinkedChannels": ["telegram"]
          },
          "message": {},
          "delivery": {
            "channels": ["telegram"],
            "maxAttempts": 3
          },
          "retry": {
            "maxAttempts": 3,
            "backoffSeconds": [60, 60, 60]
          },
          "onFail": {
            "fallbackIntent": {
              "type": "message.send",
              "payload": {
                "recipient": {
                  "phoneNormalized": "{{input.phone}}"
                },
                "message": {},
                "delivery": {
                  "channels": ["smsc"],
                  "maxAttempts": 1
                },
                "templateKey": "rubitime:bookingAccepted"
              }
            }
          },
          "templateKey": "rubitime:bookingAccepted"
        }
      }
    ]
  },
