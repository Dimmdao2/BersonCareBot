NODE_ENV=development
HOST=127.0.0.1
PORT=5200
APP_BASE_URL=http://127.0.0.1:5200
DATABASE_URL=postgres://bcb_webapp_dev_user:password@127.0.0.1:5432/bcb_webapp_dev
SESSION_COOKIE_SECRET=dev-session-secret-min-16-chars
# Должен совпадать с INTEGRATOR_SHARED_SECRET в .env интегратора (корень репо или api.prod).
INTEGRATOR_SHARED_SECRET=dev-integrator-secret-min-16-chars
# URL интегратора для отправки SMS с кодом (dev: интегратор на 4200). Если не задан — вебапп использует заглушку (SMS не уходит).
INTEGRATOR_API_URL=http://127.0.0.1:4200
ALLOW_DEV_AUTH_BYPASS=true
ALLOWED_TELEGRAM_IDS=7924656602
ADMIN_TELEGRAM_ID=364943522
ADMIN_MAX_IDS=
DOCTOR_MAX_IDS=
