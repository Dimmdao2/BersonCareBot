NODE_ENV=production
HOST=127.0.0.1
PORT=6200
APP_BASE_URL=https://webapp.bersonservices.ru
DATABASE_URL=postgres://bcb_webapp_user:password@127.0.0.1:5432/bcb_webapp_prod
# Runtime env webapp. Cutover/backfill/reconcile DB URLs should live in a separate ops-only file,
# e.g. /opt/env/bersoncarebot/cutover.prod (see deploy/env/.env.cutover.prod.example).
SESSION_COOKIE_SECRET=replace-with-long-random-secret-min-32-chars
INTEGRATOR_SHARED_SECRET=replace-with-shared-secret-with-tgcarebot
# URL интегратора для отправки SMS с кодом (POST /api/bersoncare/send-sms). Если не задан — используется заглушка (SMS не уходит).
# INTEGRATOR_API_URL=https://tgcarebot.bersonservices.ru
ALLOW_DEV_AUTH_BYPASS=false
# Whitelist Telegram: тестовый юзер и админ
ALLOWED_TELEGRAM_IDS=7924656602
ADMIN_TELEGRAM_ID=364943522
ADMIN_MAX_IDS=
DOCTOR_MAX_IDS=
ADMIN_PHONES=+79643805480
DOCTOR_PHONES=
ALLOWED_PHONES=
# Для входа по Telegram Web App initData (когда открывают из меню без ?t=): тот же токен, что в api.prod
# TELEGRAM_BOT_TOKEN=...
