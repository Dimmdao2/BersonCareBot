# BersonCareBot — переменные окружения (полный список, имена = как в коде)
# Скопируйте в .env или в api.prod на хосте. В репозиторий коммитить только .env.example.
# Важно: в api.prod файл source'ится bash — значения с $ брать в одинарные кавычки: SMSC_API_KEY='...'

# --- Сервер (корневой .env — для dev; на проде в api.prod задают PORT=3200) ---
NODE_ENV=production
HOST=127.0.0.1
PORT=4200
LOG_LEVEL=info

# --- Обязательные ---
BOOKING_URL=https://example.rubitime.ru
DATABASE_URL=postgres://user:password@127.0.0.1:5432/dbname

# --- Webapp / интегратор ---
APP_BASE_URL=https://webapp.bersonservices.ru
# Один секрет для всего (минимум 16 символов) или раздельно:
INTEGRATOR_SHARED_SECRET=min-16-chars-secret
# INTEGRATOR_WEBAPP_ENTRY_SECRET=secret-for-token-t-sign-min-16
# INTEGRATOR_WEBHOOK_SECRET=secret-for-webhook-hmac-min-16

# --- Telegram (обязательно для старта API) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=364943522
TELEGRAM_WEBHOOK_SECRET=
# При true (по умолчанию) к каждому ответу пользователю без своей клавиатуры добавляется главное меню из replyMenu.json
# TELEGRAM_SEND_MENU_ON_BUTTON_PRESS=true

# --- Rubitime (webhook token = в URL вебхука, api key = для вызовов API) ---
RUBITIME_WEBHOOK_TOKEN=
RUBITIME_API_KEY=

# --- SMSC ---
SMSC_ENABLED=true
SMSC_API_KEY=
SMSC_BASE_URL=https://smsc.ru/sys/send.php

# --- Email (SMTP). Пока не заданы — sendMail не отправляет письма ---
# MAIL_FROM=noreply@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# --- Контент (опционально) ---
CONTENT_SERVICE_BASE_URL=
CONTENT_ACCESS_HMAC_SECRET=

# --- Max (чат-бот в MAX) ---
# MAX_ENABLED=true
# MAX_API_KEY=
# MAX_WEBHOOK_SECRET=
# MAX_BOT_ID=

# --- Опционально ---
DEBUG_FORWARD_ALL_EVENTS_TO_ADMIN=false
