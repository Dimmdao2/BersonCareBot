# BersonCareBot — переменные окружения
# Скопируйте в .env и заполните значения.
# Источник истины: src/config/env.ts

# --- Сервер (все опциональные, есть значения по умолчанию) ---
# HOST=127.0.0.1
# PORT=3000
# LOG_LEVEL=info

# --- Обязательные ---
# Токен бота Telegram (BotFather)
BOT_TOKEN=

# Куда слать уведомления и вопросы (Telegram ID или chat_id)
ADMIN_TELEGRAM_ID=
INBOX_CHAT_ID=

# URL страницы/сервиса записи на приём
BOOKING_URL=

# Подключение к PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# --- Опциональные ---
# Секрет для проверки webhook (header x-telegram-bot-api-secret-token).
# В production рекомендуется задать.
# TG_WEBHOOK_SECRET=

# --- Rubitime ---
# Токен для webhook Rubitime (header X-Rubitime-Token). Для локального теста используйте значение local-dev-rubitime-token.
RUBITIME_WEBHOOK_TOKEN=
