# BersonCareBot — переменные окружения
# Скопируйте в .env и заполните значения.
# Источник истины: src/config/env.ts

# --- Сервер (все опциональные, есть значения по умолчанию) ---
# HOST=127.0.0.1
# PORT=3000
# LOG_LEVEL=info

# --- Обязательные ---
# Токен бота Telegram (BotFather)
BOT_TOKEN=

# Куда слать уведомления и вопросы (Telegram ID или chat_id)
ADMIN_TELEGRAM_ID=
INBOX_CHAT_ID=

# URL страницы/сервиса записи на приём
BOOKING_URL=

# Подключение к PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# --- Опциональные ---
# Секрет для проверки webhook (header x-telegram-bot-api-secret-token).
# В production рекомендуется задать.
# TG_WEBHOOK_SECRET=

# --- SMSC (опционально) ---
# Включить реальную отправку в SMSC (по умолчанию false = stub)
SMSC_ENABLED=false
# API key из кабинета SMSC (не коммитить в репозиторий)
# SMSC_API_KEY=
# Базовый URL API SMSC
SMSC_API_BASE_URL=https://smsc.ru/sys/send.php

# --- Rubitime (обязательная) ---
# Токен для webhook Rubitime (path /webhook/rubitime/:token).
RUBITIME_WEBHOOK_TOKEN=this-is-secret-for-debug
