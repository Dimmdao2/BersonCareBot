# BersonCareBot — переменные окружения
# Скопируйте в .env и заполните значения.
# Источник истины для runtime env: src/config/env.ts

# --- Сервер (все опциональные, есть значения по умолчанию) ---
# HOST=127.0.0.1
# PORT=4200   # dev-конвенция: интегратор 4200 (см. SERVER CONVENTIONS.md)
# LOG_LEVEL=info

# --- Обязательные ---
# URL страницы/сервиса записи на приём
BOOKING_URL=

# Базовый URL отдельного сервиса с уроками/материалами
CONTENT_SERVICE_BASE_URL=

# Общий секрет для подписи временных ссылок на контент
CONTENT_ACCESS_HMAC_SECRET=

# Подключение к PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Webapp entry (опционально): базовый URL webapp и общий секрет для подписи токена
# APP_BASE_URL=https://webapp.bersonservices.ru
# INTEGRATOR_SHARED_SECRET=shared-secret-with-webapp-min-16-chars

# --- Telegram (обязательно для работы бота) ---
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_ADMIN_ID=123456789
# TELEGRAM_WEBHOOK_SECRET=...   # опционально, для проверки webhook

# --- Опциональные ---
# DEBUG: пересылать в Telegram админу краткий лог каждого входящего события
DEBUG_FORWARD_ALL_EVENTS_TO_ADMIN=false

# Прочие интеграции: src/integrations/rubitime/config.ts, src/integrations/smsc/config.ts
