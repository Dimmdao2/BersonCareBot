{
  "name": "@bersoncare/webapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 5200",
    "lint": "eslint . && bash scripts/check-media-preview-invariants.sh",
    "check:catalog-shared-primitives": "bash scripts/check-catalog-shared-primitives.sh",
    "check:media-preview-invariants": "bash scripts/check-media-preview-invariants.sh",
    "build": "NODE_ENV=production next build && bash ../../deploy/host/sync-webapp-standalone-assets.sh",
    "analyze": "ANALYZE=true next build --webpack",
    "start": "next start -H 127.0.0.1 -p 6200",
    "typecheck": "bash ../../scripts/ensure-booking-sync-built.sh && tsc --noEmit",
    "test": "bash ../../scripts/ensure-booking-sync-built.sh && vitest --run",
    "test:e2e": "bash ../../scripts/ensure-booking-sync-built.sh && vitest --run e2e/",
    "test:e2e:live": "bash ../../scripts/ensure-booking-sync-built.sh && E2E_LIVE_DEV=1 vitest --run e2e/live-dev.test.ts",
    "test:with-db": "bash ../../scripts/ensure-booking-sync-built.sh && USE_REAL_DATABASE=1 vitest --run",
    "migrate": "node scripts/run-migrations.mjs",
    "backfill-person-domain": "node scripts/backfill-person-domain.mjs",
    "backfill-communication-history": "node scripts/backfill-communication-history.mjs",
    "reconcile-person-domain": "node scripts/reconcile-person-domain.mjs",
    "reconcile-communication-domain": "node scripts/reconcile-communication-domain.mjs",
    "backfill-reminders-domain": "node scripts/backfill-reminders-domain.mjs",
    "reconcile-reminders-domain": "node scripts/reconcile-reminders-domain.mjs",
    "backfill-appointments-domain": "node scripts/backfill-appointments-domain.mjs",
    "reconcile-appointments-domain": "node scripts/reconcile-appointments-domain.mjs",
    "backfill-subscription-mailing-domain": "node scripts/backfill-subscription-mailing-domain.mjs",
    "reconcile-subscription-mailing-domain": "node scripts/reconcile-subscription-mailing-domain.mjs",
    "seed-content": "node scripts/seed-content-pages.mjs",
    "seed-booking-catalog": "tsx scripts/seed-booking-catalog-tochka-zdorovya.ts",
    "backfill-patient-bookings-v2": "tsx scripts/backfill-patient-bookings-v2.ts",
    "backfill-rubitime-compat-snapshots": "tsx scripts/backfill-rubitime-compat-snapshots.ts",
    "backfill-rubitime-history-to-patient-bookings": "tsx scripts/backfill-rubitime-history-to-patient-bookings.ts",
    "realign-webapp-integrator-user": "tsx scripts/realign-webapp-integrator-user-projection.ts",
    "integrator-push-outbox-tick": "tsx scripts/integrator-push-outbox-tick.ts",
    "db:introspect": "drizzle-kit introspect && node scripts/fix-drizzle-introspect-defaults.mjs",
    "db:introspect:fix": "node scripts/fix-drizzle-introspect-defaults.mjs",
    "db:verify-public-table-count": "node scripts/verify-drizzle-public-table-count.mjs",
    "db:migrate:drizzle": "drizzle-kit migrate",
    "db:seed-drizzle-meta": "node scripts/seed-drizzle-migrations-meta.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1026.0",
    "@aws-sdk/s3-request-presigner": "3.1026.0",
    "@base-ui/react": "^1.3.0",
    "@bersoncare/booking-rubitime-sync": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@toast-ui/editor": "^3.2.2",
    "@toast-ui/react-editor": "^3.2.3",
    "argon2": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.44.7",
    "fluent-ffmpeg": "^2.1.3",
    "isomorphic-dompurify": "^3.7.1",
    "jose": "^5.10.0",
    "libphonenumber-js": "^1.12.41",
    "lucide-react": "^1.0.1",
    "luxon": "^3.7.2",
    "next": "^16.2.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-phone-number-input": "^3.4.16",
    "recharts": "^3.8.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.15.0",
    "eslint-config-next": "^16.2.2",
    "jsdom": "^26.0.0",
    "pino-pretty": "^13.0.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.3"
  }
}
