# Webapp env: dev — webapp/.env.dev; prod — /opt/env/bersoncarebot/webapp.prod. See webapp/src/config/env.ts
NODE_ENV=development
HOST=127.0.0.1
PORT=5200
APP_BASE_URL=http://127.0.0.1:5200
DATABASE_URL=postgres://bcb_webapp_dev_user:password@127.0.0.1:5432/bcb_webapp_dev
# Required in dev and prod (min 16 chars). Never use repo-known or example values in production.
SESSION_COOKIE_SECRET=replace-with-long-random-secret
# Either set both below, or one shared secret for both entry and webhook.
INTEGRATOR_WEBAPP_ENTRY_SECRET=replace-with-entry-secret
INTEGRATOR_WEBHOOK_SECRET=replace-with-webhook-secret
# INTEGRATOR_SHARED_SECRET=optional-fallback-if-entry-and-webhook-not-set
# Для отправки SMS с кодом через интегратор: URL API интегратора (dev: http://127.0.0.1:4200). Нужен вместе с INTEGRATOR_SHARED_SECRET (или entry/webhook).
# INTEGRATOR_API_URL=http://127.0.0.1:4200
# В dev при true на странице /app показываются кнопки «Как пациент» и «Как врач/админ» для входа в браузере без Telegram. В production игнорируется.
ALLOW_DEV_AUTH_BYPASS=true
# Имя бота без @ для deep-link привязки канала (t.me/…). По умолчанию в коде: bersoncare_bot
# TELEGRAM_BOT_USERNAME=bersoncare_bot
# Кто может войти из Telegram (тестовый юзер + ID админа в whitelist — как раньше)
ALLOWED_TELEGRAM_IDS=7924656602
# Для sendMessage «вопрос из веба» и дубль в whitelist; роль кабинета врача — только по ADMIN_PHONES / DOCTOR_PHONES
ADMIN_TELEGRAM_ID=364943522
# Whitelist Max (вход); роль — только ADMIN_PHONES / DOCTOR_PHONES
ADMIN_MAX_IDS=
DOCTOR_MAX_IDS=
# Роль admin и doctor только по номеру (через запятую; нормализация как при SMS-входе)
ADMIN_PHONES=+79643805480
DOCTOR_PHONES=
# Дополнительные номера, которым разрешён вход (клиент), без повышения роли
ALLOWED_PHONES=

# Каталог файлов CMS (upload /api/media). Пусто — `var/media` относительно cwd.
# MEDIA_STORAGE_DIR=

# --- MinIO / S3 (CMS медиа): если заданы все четыре — библиотека грузит напрямую в бакет (presigned PUT).
# S3_ENDPOINT=https://fs.example.com
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_BUCKET=bersonservices-public
# S3_REGION=us-east-1
# S3_FORCE_PATH_STYLE=true

# --- Этап 5 (авторизация): новый поток входа (check-phone, PIN, мессенджер, OAuth) ---
# NEXT_PUBLIC_AUTH_V2=1
# Яндекс OAuth (все три пусты — режим отключён, API вернёт 501)
# YANDEX_OAUTH_CLIENT_ID=
# YANDEX_OAUTH_CLIENT_SECRET=
# YANDEX_OAUTH_REDIRECT_URI=
