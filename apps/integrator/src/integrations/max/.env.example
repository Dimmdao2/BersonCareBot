# Max integration. Loaded by config.ts (prefix MAX_).
# Enable: MAX_ENABLED=true
MAX_ENABLED=false
MAX_API_KEY=
MAX_WEBHOOK_SECRET=
MAX_BOT_ID=
MAX_ADMIN_CHAT_ID=
MAX_ADMIN_USER_ID=
# Новый API-эндпоинт MAX (дедлайн 2026-07-19). Без этой переменной используется дефолтный хост SDK.
# MAX_API_BASE_URL=https://platform-api2.max.ru
# Сертификат Минцифры нужен при platform-api2.max.ru — Node по умолчанию не доверяет УЦ Минцифры.
# Скачать: https://www.gosuslugi.ru/crt → «Корневой сертификат» → /etc/ssl/certs/russian_trusted_root_ca.pem
# NODE_EXTRA_CA_CERTS=/etc/ssl/certs/russian_trusted_root_ca.pem
