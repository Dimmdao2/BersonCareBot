  {
    "id": "max.diary.symptom.awaiting_title",
    "source": "max",
    "event": "message.received",
    "match": {
      "actor": { "userState": "diary.symptom.awaiting_title" },
      "input": { "textPresent": true }
    },
    "steps": [
      {
        "action": "webapp.event.emit",
        "mode": "async",
        "params": {
          "eventType": "diary.symptom.tracking.created",
          "payload": { "symptomTitle": "{{input.text}}" }
        }
      },
      {
        "action": "user.state.set",
        "mode": "sync",
        "params": {
          "channelUserId": "{{actor.channelUserId}}",
          "state": "idle"
        }
      },
      {
        "action": "message.send",
        "mode": "async",
        "params": {
          "recipient": { "chatId": "{{actor.chatId}}" },
          "templateKey": "max:diary.symptom.trackingCreated",
          "delivery": { "channels": ["max"], "maxAttempts": 1 },
          "inlineKeyboard": [[{ "text": "⬅️ К списку симптомов", "callbackData": "diary.symptom.open" }]]
        }
      }
    ]
  },
