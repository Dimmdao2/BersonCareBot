[
  {
    "id": "rubitime.record.created",
    "source": "rubitime",
    "event": "webhook.received",
    "match": {
      "input": {
        "entity": "record",
        "action": "created"
      }
    },
    "conditions": [
      {
        "kind": "context.query",
        "name": "telegramRecipient",
        "query": {
          "type": "channel.lookupByPhone",
          "phoneNormalized": "{{input.phone}}",
          "resource": "telegram"
        }
      }
    ],
    "steps": [
      {
        "action": "event.log",
        "mode": "sync",
        "params": {
          "eventStore": "booking",
          "source": "{{source}}",
          "eventType": "{{event}}",
          "eventId": "{{meta.eventId}}",
          "occurredAt": "{{meta.occurredAt}}",
          "correlationId": "{{meta.correlationId}}",
          "body": "{{input}}"
        }
      },
      {
        "action": "booking.upsert",
        "mode": "sync",
        "params": {
          "externalRecordId": "{{input.recordId}}",
          "phoneNormalized": "{{input.phone}}",
          "recordAt": "{{input.recordAt}}",
          "status": "created",
          "rubitimeStatusCode": "{{input.statusCode}}",
          "payloadJson": "{{input.record}}",
          "lastEvent": "{{input.action}}",
          "gcalEventId": "{{input.gcalEventId}}",
          "rubitimeCooperatorId": "{{input.cooperatorId}}"
        }
      },
      {
        "action": "message.send",
        "mode": "async",
        "params": {
          "recipient": {
            "chatId": "{{queries.telegramRecipient.item.chatId}}"
          },
          "message": {},
          "templateKey": "rubitime:bookingRecorded",
          "vars": {
            "recordAt": "{{input.recordAtFormatted}}"
          },
          "delivery": {
            "channels": ["telegram"],
            "maxAttempts": 1
          },
          "_when": {
            "path": "queries.telegramRecipient.item.chatId",
            "truthy": true
          }
        }
      },
      {
        "action": "message.send",
        "mode": "async",
        "params": {
          "recipient": {
            "phoneNormalized": "{{input.phone}}"
          },
          "message": {},
          "templateKey": "rubitime:bookingRecorded",
          "vars": {
            "recordAt": "{{input.recordAtFormatted}}"
          },
          "delivery": {
            "channels": ["smsc"],
            "maxAttempts": 1
          },
          "_when": {
            "path": "queries.telegramRecipient.item.chatId",
            "truthy": false
          }
        }
      }
