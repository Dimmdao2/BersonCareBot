{
  "name": "berson-care-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --dir apps/integrator dev",
    "worker:dev": "pnpm --dir apps/integrator worker:dev",
    "webapp:dev": "pnpm --dir apps/webapp dev",
    "build": "pnpm --dir apps/integrator build",
    "build:webapp": "pnpm --dir apps/webapp build",
    "build:admin": "cd admin && npm install && npm run build",
    "start": "pnpm --dir apps/integrator start",
    "webapp:start": "pnpm --dir apps/webapp start",
    "webapp:typecheck": "pnpm --dir apps/webapp typecheck",
    "worker:start": "pnpm --dir apps/integrator worker:start",
    "test": "pnpm --dir apps/integrator test",
    "test:webapp": "pnpm --dir apps/webapp test",
    "test:e2e": "pnpm --dir apps/integrator test:e2e",
    "lint": "eslint . && pnpm --dir apps/webapp run lint",
    "lint:fix": "eslint . --fix && pnpm --dir apps/webapp run lint --fix",
    "typecheck": "pnpm --dir apps/integrator typecheck && pnpm --dir apps/webapp typecheck",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:webapp && pnpm webapp:typecheck && pnpm build && pnpm build:webapp && pnpm audit --prod",
    "check": "pnpm ci",
    "audit": "pnpm audit --prod",
    "format": "prettier -w .",
    "migrate": "pnpm --dir apps/integrator run migrate",
    "db:migrate": "pnpm --dir apps/integrator run db:migrate",
    "db:migrate:prod": "pnpm --dir apps/integrator run db:migrate:prod",
    "scenarios": "pnpm --dir apps/integrator run scenarios",
    "build:host": "pnpm --dir apps/integrator build",
    "start:host": "pnpm --dir apps/integrator start",
    "worker:start:host": "pnpm --dir apps/integrator worker:start",
    "migrate:host": "pnpm --dir apps/integrator run db:migrate:prod",
    "auto-close-conversations": "pnpm --dir apps/integrator run auto-close-conversations",
    "auto-close-conversations:host": "pnpm --dir apps/integrator run auto-close-conversations:host",
    "smsc:check": "pnpm --dir apps/integrator run smsc:check",
    "s3:check": "pnpm --dir apps/integrator run s3:check",
    "mail:check": "pnpm --dir apps/integrator run mail:check",
    "stage4-gate": "node scripts/stage4-release-gate.mjs",
    "stage6-gate": "node scripts/stage6-release-gate.mjs",
    "stage7-gate": "node scripts/stage7-release-gate.mjs",
    "stage9-gate": "node scripts/stage9-release-gate.mjs",
    "stage11-gate": "node scripts/stage11-release-gate.mjs",
    "stage12-gate": "node scripts/stage12-release-gate.mjs",
    "stage13-gate": "node scripts/stage13-release-gate.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "onlyBuiltDependencies": ["argon2"],
    "overrides": {
      "micromatch>picomatch": "2.3.2",
      "@dotenvx/dotenvx>picomatch": "4.0.4",
      "fdir>picomatch": "4.0.4"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-secrets": "^2.3.3",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
