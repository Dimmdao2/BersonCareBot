{
  "name": "berson-care-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test": "vitest --run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "audit": "pnpm audit --prod",
    "format": "prettier -w .",
    "migrate": "tsx src/persistence/migrate.ts",
    "db:migrate": "tsx src/persistence/migrate.ts",
    "db:migrate:prod": "node dist/persistence/migrate.js",
    "scenarios": "tsx e2e/run-webhook-scenarios.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.1",
  "dependencies": {
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "grammy": "^1.40.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.3",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-secrets": "^2.2.2",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "undici": "^7.0.0",
    "vitest": "^4.0.18"
  }
}