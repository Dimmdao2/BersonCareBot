{
  "name": "berson-care-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter @bersoncare/integrator --filter @bersoncare/webapp run dev",
    "dev:integrator": "pnpm --dir apps/integrator dev",
    "worker:dev": "pnpm --dir apps/integrator worker:dev",
    "scheduler:dev": "pnpm --dir apps/integrator scheduler:dev",
    "webapp:dev": "pnpm --dir apps/webapp dev",
    "build": "pnpm --dir packages/operator-db-schema run build && pnpm --dir packages/booking-rubitime-sync run build && pnpm --dir apps/integrator build",
    "build:webapp": "bash scripts/ensure-booking-sync-built.sh && pnpm --dir apps/webapp build",
    "build:admin": "cd admin && pnpm install && pnpm run build",
    "start": "pnpm --dir apps/integrator start",
    "webapp:start": "pnpm --dir apps/webapp start",
    "webapp:typecheck": "pnpm --dir apps/webapp typecheck",
    "worker:start": "pnpm --dir apps/integrator worker:start",
    "scheduler:start": "pnpm --dir apps/integrator scheduler:start",
    "scheduler:start:host": "pnpm --dir apps/integrator scheduler:start",
    "test": "pnpm --dir apps/integrator test",
    "test:webapp": "pnpm --dir apps/webapp test",
    "test:webapp:fast": "pnpm --dir apps/webapp test:fast",
    "test:webapp:inprocess": "pnpm --dir apps/webapp test:inprocess",
    "test:media-worker": "pnpm --dir apps/media-worker test",
    "test:e2e": "pnpm --dir apps/integrator test:e2e",
    "lint": "eslint . && pnpm --dir apps/webapp run lint",
    "lint:fix": "eslint . --fix && pnpm --dir apps/webapp run lint --fix",
    "typecheck": "bash scripts/ensure-booking-sync-built.sh && pnpm -r --parallel run typecheck",
    "check:hls-helpers-sync": "node scripts/check-hls-helpers-sync.mjs",
    "ci": "pnpm lint && pnpm typecheck && pnpm run check:hls-helpers-sync && pnpm test && pnpm test:webapp && pnpm test:media-worker && pnpm build && pnpm build:webapp && pnpm run audit",
    "ci:resume:after-lint": "pnpm typecheck && pnpm run check:hls-helpers-sync && pnpm test && pnpm test:webapp && pnpm test:media-worker && pnpm build && pnpm build:webapp && pnpm run audit",
    "ci:resume:after-typecheck": "pnpm run check:hls-helpers-sync && pnpm test && pnpm test:webapp && pnpm test:media-worker && pnpm build && pnpm build:webapp && pnpm run audit",
    "ci:resume:after-test": "pnpm test:webapp && pnpm test:media-worker && pnpm build && pnpm build:webapp && pnpm run audit",
    "ci:resume:after-test-webapp": "pnpm test:media-worker && pnpm build && pnpm build:webapp && pnpm run audit",
    "ci:resume:after-test-media-worker": "pnpm build && pnpm build:webapp && pnpm run audit",
    "ci:resume:after-build": "pnpm build:webapp && pnpm run audit",
    "ci:resume:after-build-webapp": "pnpm run audit",
    "check": "pnpm ci",
    "audit": "node scripts/registry-prod-audit.mjs",
    "format": "prettier -w .",
    "migrate": "bash scripts/migrate-all.sh",
    "migrate:prod:host": "bash scripts/migrate-all.sh",
    "migrate:webapp": "pnpm --dir apps/webapp run migrate",
    "db:migrate": "pnpm --dir apps/integrator run db:migrate",
    "db:migrate:prod": "pnpm --dir apps/integrator run db:migrate:prod",
    "scenarios": "pnpm --dir apps/integrator run scenarios",
    "build:host": "pnpm --dir apps/integrator build",
    "start:host": "pnpm --dir apps/integrator start",
    "worker:start:host": "pnpm --dir apps/integrator worker:start",
    "migrate:host": "pnpm --dir apps/integrator run db:migrate:prod",
    "auto-close-conversations": "pnpm --dir apps/integrator run auto-close-conversations",
    "auto-close-conversations:host": "pnpm --dir apps/integrator run auto-close-conversations:host",
    "smsc:check": "pnpm --dir apps/integrator run smsc:check",
    "s3:check": "pnpm --dir apps/integrator run s3:check",
    "mail:check": "pnpm --dir apps/integrator run mail:check",
    "stage4-gate": "node scripts/stage4-release-gate.mjs",
    "stage6-gate": "node scripts/stage6-release-gate.mjs",
    "stage7-gate": "node scripts/stage7-release-gate.mjs",
    "stage9-gate": "node scripts/stage9-release-gate.mjs",
    "stage11-gate": "node scripts/stage11-release-gate.mjs",
    "stage12-gate": "node scripts/stage12-release-gate.mjs",
    "stage13-gate": "node scripts/stage13-release-gate.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "sharp",
      "@ffmpeg-installer/ffmpeg",
      "@ffmpeg-installer/linux-x64",
      "@ffmpeg-installer/linux-arm64",
      "@ffmpeg-installer/darwin-x64",
      "@ffmpeg-installer/darwin-arm64"
    ],
    "overrides": {
      "postcss": ">=8.5.10",
      "fast-uri": ">=3.1.2",
      "fast-xml-builder": ">=1.1.7",
      "fast-xml-parser": ">=5.7.3",
      "fastify": ">=5.8.5",
      "jsdom": "^26.0.0",
      "flatted": ">=3.4.2",
      "dompurify": ">=3.4.0",
      "@esbuild-kit/core-utils>esbuild": "0.27.4",
      "micromatch>picomatch": "2.3.2",
      "@dotenvx/dotenvx>picomatch": "4.0.4",
      "fdir>picomatch": "4.0.4",
      "path-to-regexp": ">=8.4.0",
      "hono": ">=4.12.16",
      "@hono/node-server": ">=1.19.13",
      "ip-address": ">=10.2.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-secrets": "^2.3.3",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  }
}
