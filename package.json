{
  "name": "berson-care-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "worker:dev": "tsx watch src/infra/runtime/worker/main.ts",
    "webapp:dev": "pnpm --dir webapp dev",
    "clean": "rm -rf dist",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "build:webapp": "pnpm --dir webapp build",
    "build:admin": "cd admin && npm install && npm run build",
    "start": "node dist/main.js",
    "webapp:start": "pnpm --dir webapp start",
    "webapp:typecheck": "pnpm --dir webapp typecheck",
    "worker:start": "node dist/infra/runtime/worker/main.js",
    "test": "vitest --run",
    "test:webapp": "pnpm --dir webapp test",
    "test:e2e": "RUN_E2E_TESTS=true vitest --run e2e/*.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:webapp && pnpm webapp:typecheck && pnpm build && pnpm audit --prod",
    "check": "pnpm ci",
    "audit": "pnpm audit --prod",
    "format": "prettier -w .",
    "migrate": "tsx src/infra/db/migrate.ts",
    "db:migrate": "tsx src/infra/db/migrate.ts",
    "db:migrate:prod": "node dist/infra/db/migrate.js",
    "scenarios": "tsx e2e/run-webhook-scenarios.ts",
    "build:host": "pnpm run build",
    "start:host": "node dist/main.js",
    "worker:start:host": "node dist/infra/runtime/worker/main.js",
    "migrate:host": "node dist/infra/db/migrate.js",
    "auto-close-conversations": "tsx src/infra/scripts/auto-close-stale-conversations.ts",
    "auto-close-conversations:host": "node dist/infra/scripts/auto-close-stale-conversations.js",
    "smsc:check": "tsx src/infra/scripts/check-smsc.ts",
    "s3:check": "tsx src/infra/scripts/check-s3.ts",
    "mail:check": "tsx src/infra/scripts/check-mail.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.1",
  "dependencies": {
    "@maxhub/max-bot-api": "^0.2.2",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "grammy": "^1.41.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.2",
    "p-retry": "^7.1.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-secrets": "^2.3.3",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "undici": "^7.24.3",
    "vitest": "^4.1.0"
  }
}