{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
      "strict": true, // Keep existing strict option
      "noImplicitAny": true, // Keep existing noImplicitAny option
      "noUncheckedIndexedAccess": true, // Add new option
      "exactOptionalPropertyTypes": true, // Add new option
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  },
  "include": ["src", "e2e"],
  "exclude": ["node_modules", "dist"]
}
